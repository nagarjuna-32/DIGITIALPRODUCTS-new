PORT=5000
DATABASE_URL="postgresql://username:password@host:port/database_name?schema=public"
JWT_SECRET="your-jwt-signing-secret"
FRONTEND_URL="http://localhost:3000"

# Razorpay API Credentials
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Cloudflare R2 Credentials (S3 Compatible API)
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-cloudflare-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-cloudflare-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="your-cloudflare-r2-bucket-name"
CLOUDFLARE_R2_PUBLIC_URL="https://your-public-cdn-subdomain.com" # Optional

# SMTP Mail Server Credentials
SMTP_HOST="smtp.yourmailserver.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM='"Digital Vault" <noreply@yourdomain.com>'
